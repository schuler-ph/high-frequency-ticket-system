{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "workspace:verify:quick",
      "type": "shell",
      "command": "source \"$HOME/.nvm/nvm.sh\" && nvm use --silent >/dev/null && pnpm run verify:quick",
      "group": "test",
      "problemMatcher": [],
      "options": {
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      }
    },
    {
      "label": "workspace:verify:all",
      "type": "shell",
      "command": "source \"$HOME/.nvm/nvm.sh\" && nvm use --silent >/dev/null && pnpm run verify:all",
      "group": "test",
      "problemMatcher": [],
      "options": {
        "shell": {
          "executable": "/bin/zsh",
          "args": ["-lc"]
        }
      }
    },
    {
      "label": "api:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "api", "run", "build"],
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "api:watch",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "api", "run", "watch"],
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
