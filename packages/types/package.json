{
  "name": "@repo/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./tickets": {
      "types": "./src/tickets.ts",
      "source": "./src/tickets.ts",
      "default": "./dist/tickets.js"
    },
    "./errors": {
      "types": "./src/errors.ts",
      "source": "./src/errors.ts",
      "default": "./dist/errors.js"
    },
    "./health": {
      "types": "./src/health.ts",
      "source": "./src/health.ts",
      "default": "./dist/health.js"
    },
    "./redis-keys": {
      "types": "./src/redis-keys.ts",
      "source": "./src/redis-keys.ts",
      "default": "./dist/redis-keys.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.3.3",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  }
}
