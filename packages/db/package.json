{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "default": "./dist/src/schema.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "seed": "node --import tsx src/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:apply-sql": "node --import tsx scripts/apply-sql-migration.ts",
    "db:studio": "drizzle-kit studio",
    "db:test": "node --import tsx --test test/**/*.test.ts",
    "debug:ticket-order-fk": "node --import tsx scripts/debug-ticket-order-fk.ts",
    "debug:buy-ticket-function": "node --import tsx scripts/debug-buy-ticket-function.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsgo --noEmit"
  },
  "dependencies": {
    "@repo/env": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
