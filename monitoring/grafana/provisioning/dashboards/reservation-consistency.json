{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(reservations_created_total{job=\"api\"}[1m]))",
          "legendFormat": "Reservations Created / s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(publish_rollbacks_total{job=\"api\"}[1m])) or vector(0)",
          "legendFormat": "Publish Rollbacks / s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(worker_compensations_total{job=\"worker\"}[1m])) or vector(0)",
          "legendFormat": "Worker Compensations / s",
          "refId": "C"
        }
      ],
      "title": "Reservation Flow (Created / Rollbacks / Compensations)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "(sum(increase(publish_rollbacks_total{job=\"api\"}[5m])) or vector(0)) / (sum(increase(reservations_created_total{job=\"api\"}[5m])) > 0)",
          "legendFormat": "Rollback Rate (5m)",
          "refId": "A"
        }
      ],
      "title": "Publish Rollback Rate (5m)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "(sum(increase(worker_compensations_total{job=\"worker\"}[5m])) or vector(0)) / (sum(increase(reservations_created_total{job=\"api\"}[5m])) > 0)",
          "legendFormat": "Compensation Rate (5m)",
          "refId": "A"
        }
      ],
      "title": "Worker Compensation Rate (5m)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Redis-DB Drift" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "last", "min", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "redis_db_drift_tickets{job=\"worker\"}",
          "legendFormat": "Redis-DB Drift ({{event_id}})",
          "refId": "A"
        }
      ],
      "title": "Redis-DB Drift — redis_available − (capacity − sold_count − active_reservations)",
      "description": "Value 0 = perfect consistency. Positive = Redis has more available slots than DB. Negative = Redis has fewer (rare, after worker restart).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short",
          "noValue": "no data"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "abs(redis_db_drift_tickets{job=\"worker\"})",
          "legendFormat": "|Drift| {{event_id}}",
          "refId": "A"
        }
      ],
      "title": "Current Drift (absolute)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (event_id) (rate(reservations_created_total{job=\"api\"}[1m]))",
          "legendFormat": "reservations {{event_id}}",
          "refId": "A"
        },
        {
          "expr": "sum by (event_id) (rate(publish_rollbacks_total{job=\"api\"}[1m]))",
          "legendFormat": "rollbacks {{event_id}}",
          "refId": "B"
        }
      ],
      "title": "Reservations & Rollbacks by Event",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hts", "reservations", "consistency"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Reservation & Consistency",
  "uid": "hts-reservation-consistency",
  "version": 1
}
