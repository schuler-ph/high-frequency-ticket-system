      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, status) (rate(order_e2e_latency_seconds_bucket{job=\"worker\"}[1m])))",
          "legendFormat": "p50 ({{status}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(order_e2e_latency_seconds_bucket{job=\"worker\"}[1m])))",
          "legendFormat": "p95 ({{status}})",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, status) (rate(order_e2e_latency_seconds_bucket{job=\"worker\"}[1m])))",
          "legendFormat": "p99 ({{status}})",
          "refId": "C"
        }
      ],
      "title": "Order Completion Latency — POST /buy → completed | failed (p50 / p95 / p99)",
      "type": "timeseries"
    },
