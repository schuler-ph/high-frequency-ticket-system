{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(worker_redeliveries_total{job=\"worker\"}[1m])) or vector(0)",
          "legendFormat": "Redeliveries / s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(worker_idempotency_hits_total{job=\"worker\"}[1m])) or vector(0)",
          "legendFormat": "Idempotency Hits / s",
          "refId": "B"
        },
        {
          "expr": "sum(rate(worker_compensations_total{job=\"worker\"}[1m])) or vector(0)",
          "legendFormat": "Compensations / s",
          "refId": "C"
        }
      ],
      "title": "Worker Reliability Events (rate per second)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "sum(increase(worker_redeliveries_total{job=\"worker\"}[5m])) or vector(0)",
          "legendFormat": "Redeliveries (5m)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(worker_idempotency_hits_total{job=\"worker\"}[5m])) or vector(0)",
          "legendFormat": "Idempotency Hits (5m)",
          "refId": "B"
        },
        {
          "expr": "sum(increase(worker_compensations_total{job=\"worker\"}[5m])) or vector(0)",
          "legendFormat": "Compensations (5m)",
          "refId": "C"
        }
      ],
      "title": "Reliability Event Counts (last 5 minutes)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "(sum(rate(worker_redeliveries_total{job=\"worker\"}[1m])) or vector(0)) / (sum(rate(orders_accepted_total{job=\"api\"}[1m])) > 0)",
          "legendFormat": "Redelivery Rate",
          "refId": "A"
        },
        {
          "expr": "(sum(rate(worker_compensations_total{job=\"worker\"}[1m])) or vector(0)) / (sum(rate(orders_accepted_total{job=\"api\"}[1m])) > 0)",
          "legendFormat": "Compensation Rate",
          "refId": "B"
        }
      ],
      "title": "Redelivery & Compensation Rate (vs. accepted orders)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (event_id) (rate(worker_redeliveries_total{job=\"worker\"}[1m]))",
          "legendFormat": "redeliveries {{event_id}}",
          "refId": "A"
        },
        {
          "expr": "sum by (event_id) (rate(worker_compensations_total{job=\"worker\"}[1m]))",
          "legendFormat": "compensations {{event_id}}",
          "refId": "B"
        }
      ],
      "title": "Reliability Events by Event",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(increase(worker_redeliveries_total{job=\"worker\"}[$__range]))",
          "legendFormat": "Total Redeliveries",
          "refId": "A"
        },
        {
          "expr": "sum(increase(worker_idempotency_hits_total{job=\"worker\"}[$__range]))",
          "legendFormat": "Total Idempotency Hits",
          "refId": "B"
        },
        {
          "expr": "sum(increase(worker_compensations_total{job=\"worker\"}[$__range]))",
          "legendFormat": "Total Compensations",
          "refId": "C"
        }
      ],
      "title": "Cumulative Reliability Events (Dashboard Time Range)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["hts", "worker", "reliability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Worker Reliability",
  "uid": "hts-worker-reliability",
  "version": 1
}
