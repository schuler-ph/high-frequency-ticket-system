{
  "name": "high-frequency-ticket-system",
  "private": true,
  "scripts": {
    "spike": "node --env-file-if-exists=.env scripts/local/run-spike.mjs",
    "spike:report": "node --env-file-if-exists=.env scripts/load-test/run-and-report.mjs",
    "spike:analyze": "node scripts/load-test/analyze-run.mjs",
    "spike:compare": "node scripts/load-test/compare-runs.mjs",
    "spike:report:test": "node --test \"scripts/load-test/test/**/*.test.mjs\"",
    "bench:hot-row": "node --env-file-if-exists=.env scripts/local/bench-hot-row.mjs",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "seed": "node --env-file-if-exists=.env scripts/local/reset-seed.mjs",
    "db:apply-sql": "pnpm --filter @repo/db run db:apply-sql",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "preflight:test": "node scripts/debug/preflight-test.mjs",
    "test": "pnpm run preflight:test && turbo run test --ui=stream --concurrency=1",
    "test:ci": "pnpm run preflight:test && turbo run test:ci --ui=stream --concurrency=1",
    "debug:runtime": "node scripts/debug/print-runtime.mjs",
    "debug:migrations": "node scripts/debug/check-migrations.mjs",
    "debug:buy-ticket-contract": "node scripts/debug/check-buy-ticket-contract.mjs",
    "debug:db:ticket-order-fk": "pnpm --filter @repo/db run debug:ticket-order-fk",
    "debug:db:buy-ticket-function": "pnpm --filter @repo/db run debug:buy-ticket-function",
    "debug:all": "pnpm run debug:runtime && pnpm run debug:migrations && pnpm run debug:buy-ticket-contract",
    "verify:quick": "pnpm run format:check && pnpm run debug:all && pnpm run lint && pnpm run check-types && pnpm run test",
    "verify:all": "pnpm run format:check && pnpm run debug:all && pnpm run lint && pnpm run check-types && pnpm run test:ci && pnpm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260319.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.11",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
  "engines": {
    "node": ">=22"
  }
}
